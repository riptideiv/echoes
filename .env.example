# Required for generation.
DEEPSEEK_API_KEY=

# Optional overrides. Defaults are shown here.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
WINDOW_DAYS=7
GEN_TEMPERATURE=0.8
TAG_TEMPERATURE=0.2

# Optional local paths.
# CLAUDE_PROJECTS_DIR defaults to ~/.claude/projects
# DB_PATH defaults to ./data.db
# BROWSERS_CONFIG defaults to ./config/browsers.json
# HISTORY_PATH defaults to ./history.json for legacy JSON export fallback
# CLAUDE_PROJECTS_DIR=~/.claude/projects
# DB_PATH=./data.db
# BROWSERS_CONFIG=./config/browsers.json
# HISTORY_PATH=./history.json

# Optional trusted local extension entry point (absolute path to an ESM file).
# ECHOES_EXTENSION_PATH=/absolute/path/to/extension/dist/server.mjs
